@using ContosoDashboard.Models

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Edit Document</h5>
        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OnCancel.InvokeAsync()">Close</button>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Title</label>
                <input class="form-control" @bind="title" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Category</label>
                <select class="form-select" @bind="category">
                    @foreach (var item in Categories)
                    {
                        <option value="@item">@item</option>
                    }
                </select>
            </div>
            <div class="col-12">
                <label class="form-label">Description</label>
                <textarea class="form-control" rows="3" @bind="description"></textarea>
            </div>
            <div class="col-12">
                <label class="form-label">Tags</label>
                <input class="form-control" @bind="tagsText" />
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-end gap-2">
            <button class="btn btn-secondary" @onclick="() => OnCancel.InvokeAsync()">Cancel</button>
            <button class="btn btn-primary" @onclick="SaveAsync">Save Changes</button>
        </div>
    </div>
</div>

@code {
    private static readonly string[] Categories = ["Project Documents", "Team Resources", "Personal Files", "Reports", "Presentations", "Other"];

    [Parameter, EditorRequired]
    public DocumentDetailsResponse Document { get; set; } = null!;

    [Parameter]
    public EventCallback<DocumentUpdateRequest> OnSave { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private string title = string.Empty;
    private string category = Categories[0];
    private string? description;
    private string tagsText = string.Empty;

    protected override void OnParametersSet()
    {
        title = Document.Title;
        category = Document.Category;
        description = Document.Description;
        tagsText = string.Join(", ", Document.Tags);
    }

    private Task SaveAsync()
    {
        return OnSave.InvokeAsync(new DocumentUpdateRequest
        {
            Title = title,
            Category = category,
            Description = description,
            Tags = tagsText.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList()
        });
    }
}